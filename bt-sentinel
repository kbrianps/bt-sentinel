#!/bin/bash

set -euo pipefail

VERSION="0.2.0"
POLL_INTERVAL="${BT_SENTINEL_INTERVAL:-5}"
RECONNECT_DELAY="${BT_SENTINEL_RECONNECT_DELAY:-2}"
MAX_RETRIES="${BT_SENTINEL_MAX_RETRIES:-2}"
VERBOSE="${BT_SENTINEL_VERBOSE:-0}"
OOB_THRESHOLD="${BT_SENTINEL_OOB_THRESHOLD:-3}"
COOLDOWN="${BT_SENTINEL_COOLDOWN:-30}"
KEY_SYNC_FAILURE_THRESHOLD="${BT_SENTINEL_KEY_SYNC_THRESHOLD:-1}"
SCAN_DURATION="${BT_SENTINEL_SCAN_DURATION:-30}"
AUTO_REPAIR="${BT_SENTINEL_AUTO_REPAIR:-1}"

declare -A LAST_RECONNECT
declare -A CONNECT_FAILURES

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

debug() {
  if [[ "$VERBOSE" -eq 1 ]]; then
    log "[DEBUG] $1"
  fi
}

usage() {
  cat <<EOF
bt-sentinel v${VERSION}
Bluetooth watchdog for Linux (PipeWire/BlueZ)

Monitors and fixes common Bluetooth audio issues:
  1. Silent headphones caused by PipeWire node error state
  2. Silent headphones caused by WirePlumber buffer exhaustion
  3. Paired device not reconnecting after switching from another device
  4. Auto-repair after key desync (remove + re-pair with notification)

Usage: bt-sentinel [OPTIONS]

Options:
  -d, --daemon        Run in daemon mode (continuous monitoring)
  -i, --interval SEC  Polling interval in seconds (default: 5)
  -v, --verbose       Enable verbose logging
  -h, --help          Show this help message
  --version           Show version

Environment variables:
  BT_SENTINEL_INTERVAL        Polling interval in seconds (default: 5)
  BT_SENTINEL_RECONNECT_DELAY Delay between disconnect/connect (default: 2)
  BT_SENTINEL_MAX_RETRIES     Max reconnection attempts (default: 3)
  BT_SENTINEL_OOB_THRESHOLD   Out-of-buffers count to trigger fix (default: 3)
  BT_SENTINEL_COOLDOWN        Seconds between reconnects per device (default: 30)
  BT_SENTINEL_KEY_SYNC_THRESHOLD  Failures before auto-repair (default: 3)
  BT_SENTINEL_SCAN_DURATION   Scan timeout when repairing (default: 30s)
  BT_SENTINEL_AUTO_REPAIR     Enable auto remove+pair (default: 1)
EOF
}

check_dependencies() {
  local missing=()
  for cmd in bluetoothctl wpctl pw-cli journalctl; do
    if ! command -v "$cmd" &>/dev/null; then
      missing+=("$cmd")
    fi
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    log "[ERROR] Missing dependencies: ${missing[*]}"
    log "Install: sudo apt install bluez pipewire wireplumber systemd"
    exit 1
  fi
}

in_cooldown() {
  local mac="$1"
  local now last
  now=$(date +%s)
  last="${LAST_RECONNECT[$mac]:-0}"
  (( now - last < COOLDOWN ))
}

mark_reconnected() {
  local mac="$1"
  LAST_RECONNECT[$mac]=$(date +%s)
}

get_paired_devices() {
  bluetoothctl devices Paired 2>/dev/null | awk '{print $2}'
}

get_connected_devices() {
  bluetoothctl devices Connected 2>/dev/null | awk '{print $2}'
}

get_device_name() {
  local mac="$1"
  bluetoothctl info "$mac" 2>/dev/null | grep -m1 "Alias:" | sed 's/.*Alias: //'
}

is_audio_device() {
  local mac="$1"
  bluetoothctl info "$mac" 2>/dev/null | grep -q "Audio Sink\|Audio Source\|Handsfree\|Advanced Audio"
}

is_trusted() {
  local mac="$1"
  bluetoothctl info "$mac" 2>/dev/null | grep -q "Trusted: yes"
}

mac_to_pw_name() {
  local mac="$1"
  echo "bluez_output.${mac//:/_}"
}

get_bt_sink_id() {
  local mac="$1"
  local pw_name
  pw_name=$(mac_to_pw_name "$mac")

  pw-cli ls Node 2>/dev/null | awk -v target="$pw_name" '
    /^\tid [0-9]+/ { id = $2; sub(",", "", id) }
    $0 ~ "node.name = \"" target { print id; exit }
  '
}

get_bt_node_state() {
  local sink_id="$1"
  pw-cli info "$sink_id" 2>/dev/null | grep -oP 'state:\s*"\K[^"]+' || echo "unknown"
}

check_node_error() {
  local mac="$1"
  local sink_id
  sink_id=$(get_bt_sink_id "$mac")

  if [[ -z "$sink_id" ]]; then
    return 1
  fi

  local state
  state=$(get_bt_node_state "$sink_id")
  debug "Node $sink_id state: $state"

  [[ "$state" == "error" ]]
}

check_out_of_buffers() {
  local mac="$1"

  local sink_id
  sink_id=$(get_bt_sink_id "$mac")
  [[ -z "$sink_id" ]] && return 1

  local oob_count
  oob_count=$(journalctl --user -u wireplumber --since "-${COOLDOWN}s" --no-pager 2>/dev/null \
    | grep -c "out of buffers" || true)

  debug "Out-of-buffers count (last ${COOLDOWN}s): $oob_count"

  [[ "$oob_count" -ge "$OOB_THRESHOLD" ]]
}

check_pipewire_error_log() {
  local mac="$1"
  local pw_name
  pw_name=$(mac_to_pw_name "$mac")

  local error_count
  error_count=$(journalctl --user -u pipewire --since "-${COOLDOWN}s" --no-pager 2>/dev/null \
    | grep -c "error\|Error" || true)

  local node_errors
  node_errors=$(journalctl --user -u pipewire --since "-${COOLDOWN}s" --no-pager 2>/dev/null \
    | grep -c "${pw_name}.*error" || true)

  debug "PipeWire errors (last ${COOLDOWN}s): general=$error_count node=$node_errors"

  [[ "$node_errors" -ge 1 ]]
}

notify() {
  local title="$1"
  local body="$2"
  local urgency="${3:-normal}"

  if command -v notify-send &>/dev/null; then
    notify-send -u "$urgency" -i bluetooth "$title" "$body" 2>/dev/null || true
  fi
}

is_key_sync_error() {
  local output="$1"
  echo "$output" | grep -qE "br-connection-unknown|br-connection-canceled|Protocol not available|Authentication Failed"
}

auto_repair_device() {
  local mac="$1"
  local name
  name=$(get_device_name "$mac")
  [[ -z "$name" ]] && name="$mac"

  log "[AUTO-REPAIR] Starting for $name ($mac)"
  notify "Bluetooth key desync" "Put $name in pairing mode to auto-pair" "critical"

  bluetoothctl disconnect "$mac" &>/dev/null || true
  sleep 1
  bluetoothctl remove "$mac" &>/dev/null || true
  sleep 2

  log "[AUTO-REPAIR] Scanning for up to $SCAN_DURATION seconds..."
  bluetoothctl --timeout "$SCAN_DURATION" scan on &>/dev/null &
  local scan_pid=$!

  local waited=0
  local found=0
  while [[ $waited -lt $SCAN_DURATION ]]; do
    if bluetoothctl devices 2>/dev/null | grep -q "$mac"; then
      found=1
      break
    fi
    sleep 1
    waited=$((waited + 1))
  done

  kill "$scan_pid" 2>/dev/null || true
  wait "$scan_pid" 2>/dev/null || true
  bluetoothctl scan off &>/dev/null || true

  if [[ $found -eq 0 ]]; then
    log "[AUTO-REPAIR] Timed out - device not in pairing mode"
    notify "Bluetooth auto-repair failed" "$name not found. Put it in pairing mode and retry." "critical"
    unset "CONNECT_FAILURES[$mac]"
    return 1
  fi

  log "[AUTO-REPAIR] Device found, attempting pair"
  if bluetoothctl pair "$mac" 2>/dev/null | grep -q "successful"; then
    bluetoothctl trust "$mac" &>/dev/null || true
    sleep 1
    if bluetoothctl connect "$mac" 2>/dev/null | grep -q "successful"; then
      log "[AUTO-REPAIR] Success for $name ($mac)"
      notify "Bluetooth repaired" "$name paired and connected" "normal"
      unset "CONNECT_FAILURES[$mac]"
      mark_reconnected "$mac"
      return 0
    fi
  fi

  log "[AUTO-REPAIR] Failed for $name ($mac)"
  notify "Bluetooth auto-repair failed" "Could not re-pair $name" "critical"
  unset "CONNECT_FAILURES[$mac]"
  return 1
}

reconnect_device() {
  local mac="$1"
  local reason="${2:-unknown}"
  local name
  name=$(get_device_name "$mac")

  if in_cooldown "$mac"; then
    debug "Skipping $name ($mac) - in cooldown"
    return 0
  fi

  local attempt=0
  local last_output=""
  while [[ $attempt -lt $MAX_RETRIES ]]; do
    attempt=$((attempt + 1))
    log "[RECONNECT] $name ($mac) - reason: $reason - attempt $attempt/$MAX_RETRIES"

    bluetoothctl disconnect "$mac" &>/dev/null || true
    sleep "$RECONNECT_DELAY"

    last_output=$(bluetoothctl connect "$mac" 2>&1 || true)
    if echo "$last_output" | grep -q "successful"; then
      log "[OK] $name ($mac) reconnected"
      mark_reconnected "$mac"
      unset "CONNECT_FAILURES[$mac]"
      return 0
    fi

    sleep "$RECONNECT_DELAY"
  done

  log "[FAIL] $name ($mac) - could not reconnect after $MAX_RETRIES attempts"
  mark_reconnected "$mac"

  if is_key_sync_error "$last_output"; then
    local failures="${CONNECT_FAILURES[$mac]:-0}"
    failures=$((failures + 1))
    CONNECT_FAILURES[$mac]=$failures
    log "[KEY-SYNC] $name ($mac) connection failures: $failures/$KEY_SYNC_FAILURE_THRESHOLD"

    if [[ "$AUTO_REPAIR" -eq 1 && $failures -ge $KEY_SYNC_FAILURE_THRESHOLD ]]; then
      auto_repair_device "$mac"
    fi
  fi

  return 1
}

fix_broken_audio() {
  local connected
  connected=$(get_connected_devices)

  for mac in $connected; do
    is_audio_device "$mac" || continue

    local name
    name=$(get_device_name "$mac")

    if check_node_error "$mac"; then
      log "[DETECTED] Node error on $name ($mac)"
      reconnect_device "$mac" "node-error"
    elif check_out_of_buffers "$mac"; then
      log "[DETECTED] Buffer exhaustion on $name ($mac)"
      reconnect_device "$mac" "out-of-buffers"
    elif check_pipewire_error_log "$mac"; then
      log "[DETECTED] PipeWire error log for $name ($mac)"
      reconnect_device "$mac" "pipewire-error-log"
    else
      debug "Audio OK for $name"
    fi
  done
}

try_reconnect_missing() {
  local paired connected
  paired=$(get_paired_devices)
  connected=$(get_connected_devices)

  for mac in $paired; do
    is_audio_device "$mac" || continue
    is_trusted "$mac" || continue

    if ! echo "$connected" | grep -q "$mac"; then
      local name
      name=$(get_device_name "$mac")
      debug "Paired but disconnected: $name ($mac)"

      local output
      output=$(bluetoothctl connect "$mac" 2>&1 || true)
      if echo "$output" | grep -q "successful"; then
        log "[CONNECTED] $name ($mac) - auto-reconnected"
        unset "CONNECT_FAILURES[$mac]"
      elif is_key_sync_error "$output"; then
        local failures="${CONNECT_FAILURES[$mac]:-0}"
        failures=$((failures + 1))
        CONNECT_FAILURES[$mac]=$failures
        log "[KEY-SYNC] $name ($mac) connection failures: $failures/$KEY_SYNC_FAILURE_THRESHOLD"

        if [[ "$AUTO_REPAIR" -eq 1 && $failures -ge $KEY_SYNC_FAILURE_THRESHOLD ]]; then
          auto_repair_device "$mac"
        fi
      else
        debug "Could not reach $name ($mac) - device may be off or paired elsewhere"
      fi
    fi
  done
}

run_once() {
  debug "Running single check..."
  fix_broken_audio
  try_reconnect_missing
}

run_daemon() {
  log "bt-sentinel v${VERSION} started (interval: ${POLL_INTERVAL}s)"
  trap 'log "bt-sentinel stopped"; exit 0' SIGTERM SIGINT

  while true; do
    run_once
    sleep "$POLL_INTERVAL"
  done
}

main() {
  local daemon=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--daemon) daemon=1; shift ;;
      -i|--interval) POLL_INTERVAL="$2"; shift 2 ;;
      -v|--verbose) VERBOSE=1; shift ;;
      -h|--help) usage; exit 0 ;;
      --version) echo "bt-sentinel v${VERSION}"; exit 0 ;;
      *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
  done

  check_dependencies

  if [[ $daemon -eq 1 ]]; then
    run_daemon
  else
    run_once
  fi
}

main "$@"
